# Discord Bot
DISCORD_TOKEN=tu_token_aqui
DISCORD_PREFIX=/

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/musicbot
DATABASE_URL_DEV=sqlite:///./musicbot.db

# Spotify API
SPOTIFY_CLIENT_ID=tu_client_id
SPOTIFY_CLIENT_SECRET=tu_client_secret

# Lavalink Server
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# YouTube
YOUTUBE_API_KEY=tu_key_opcional

# Bot Configuration
NODE_ENV=development
LOG_LEVEL=INFO
BOT_PREFIX=/

# Sentry (optional)
SENTRY_DSN=

# Features
ENABLE_SPOTIFY=true
ENABLE_YOUTUBE=true
ENABLE_SOUNDCLOUD=false

# Performance
CACHE_TTL=3600
MAX_QUEUE_SIZE=500
